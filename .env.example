# ============================================================
# PolyRader CS2 — Environment Configuration
# ============================================================
# In Tauri desktop mode, most settings come from config.json.
# This file is for standalone development without Tauri.
# ============================================================

# Database (SQLite file path)
DATABASE_URL=data/polyrader.db

# Polymarket (public APIs, no auth required)
POLYMARKET_GAMMA_API_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_API_URL=https://clob.polymarket.com
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws

# Polygon RPC (for whale tracking)
POLYGON_RPC_URL=https://polygon-rpc.com

# LLM API Keys (all optional — only configured providers are used)
# --- 国际模型 ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
GROQ_API_KEY=
# --- 国产模型 ---
QWEN_API_KEY=
MOONSHOT_API_KEY=
ZHIPU_API_KEY=
DOUBAO_API_KEY=
MINIMAX_API_KEY=
HUNYUAN_API_KEY=

# LLM Base URLs (optional — override API endpoints, e.g. for proxies)
OPENAI_BASE_URL=
ANTHROPIC_BASE_URL=
GOOGLE_BASE_URL=
DEEPSEEK_BASE_URL=
XAI_BASE_URL=
GROQ_BASE_URL=
QWEN_BASE_URL=
MOONSHOT_BASE_URL=
ZHIPU_BASE_URL=
DOUBAO_BASE_URL=
MINIMAX_BASE_URL=
HUNYUAN_BASE_URL=

# Encryption key for API key storage
# Tauri mode: auto-generated in config.json
# Standalone: generate with `openssl rand -base64 32`
ENCRYPTION_KEY=

# Server (standalone mode only)
NODE_ENV=development
PORT=3001
# WS_PORT is unused — WebSocket shares the HTTP PORT
WS_PORT=3002
CORS_ORIGIN=http://localhost:5173
