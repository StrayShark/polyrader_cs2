{
  "name": "polyrader-cs2",
  "version": "0.2.0",
  "private": true,
  "description": "Open-source Polymarket CS2 esports prediction analysis tool",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "npm run dev --workspace=packages/web",
    "build": "turbo run build",
    "build:web": "npm run build --workspace=packages/web",
    "build:server": "npm run build:bundle --workspace=packages/server",
    "tauri": "cargo tauri",
    "tauri:dev": "cargo tauri dev",
    "tauri:build": "cargo tauri build",
    "lint": "turbo run lint",
    "knip": "knip",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "npm run test:e2e --workspace=@polyrader/web",
    "clean": "turbo run clean",
    "format": "prettier --write \"packages/**/*.{ts,tsx,json,css}\""
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "knip": "^5.88.1",
    "prettier": "^3.4.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.9.2"
}
